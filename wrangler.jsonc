{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hitorigotolab",
  "compatibility_date": "2026-06-11",
  "observability": {
    "enabled": true
  },
  // /l/* はチャネル帰属のインタースティシャル（worker/index.js 参照）。ここには asset が無いので
  // worker を先に通す。それ以外は従来どおり静的 assets + _redirects を配信。
  "main": "worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/l/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
