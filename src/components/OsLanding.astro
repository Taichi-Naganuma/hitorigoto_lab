---
// 自走OS「Mioca」の準備中/先行登録LP。関連試作（自走OS LPヒーロー／Features）に追従。
// 主役＝運転してる感（ヒーロー右のライブ・コンソール＝動作イメージと明示）。誠実は担保として並走。
// 意匠の署名＝シアン→パープルのグラデ境界線（回転アニメで前面化）。モーションは prefers-reduced-motion で全停止。
import LangSwitcher from './LangSwitcher.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  d: any; // os collection entry data
}
const { locale, d } = Astro.props;
const isJa = locale === 'ja';
const t = useTranslations(locale);
const homeUrl = getRelativeLocaleUrl(locale, '/');

// ── 先行登録の受付先（Tally）───────────────────────────────────────────────
// オーナー提供の Tally 先行登録フォーム。空にすると CTA は「準備中」表示に戻る（床）。
const WAITLIST_URL = 'https://tally.so/r/VLAPeM';
const waitlistOn = WAITLIST_URL.trim().length > 0;
const soonLabel = isJa ? '先行登録（準備中）' : 'Waitlist — opening soon';

const nav = isJa
  ? [{ l: '機能', h: '#cap' }, { l: 'しくみ', h: '#how' }, { l: '料金', h: '#pricing' }, { l: 'よくある質問', h: '#faq' }]
  : [{ l: 'Features', h: '#cap' }, { l: 'How', h: '#how' }, { l: 'Pricing', h: '#pricing' }, { l: 'FAQ', h: '#faq' }];

const arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
const iconCheck = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>';
const iconRun = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.22-8.56"/></svg>';
const capIcons = [
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L4.5 13.5H12l-1 8.5 8.5-11.5H12z"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="4"/><path d="M16.5 11l2 2 4-4"/></svg>',
];
---

<div class="os-landing">
  <header class="nav">
    <a class="brand" href={homeUrl} aria-label={d.brand}>
      <span class="brand-glyph"></span><span class="brand-name">{d.brand}</span>
      <span class="brand-status">{d.status}</span>
    </a>
    <nav class="nav-links" aria-label="section">
      {nav.map((n) => <a href={n.h}>{n.l}</a>)}
    </nav>
    <div class="nav-right">
      <LangSwitcher locale={locale} />
      {waitlistOn ? (
        <a class="lp-btn primary sm" href={WAITLIST_URL} target="_blank" rel="noopener">{d.ctaPrimary}</a>
      ) : (
        <span class="lp-btn primary sm is-soon" aria-disabled="true">{soonLabel}</span>
      )}
    </div>
  </header>

  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow"><span class="dot"></span>{d.eyebrow}</span>
      <h1 class="lp-h1" set:html={d.headline} />
      <span class="h1-rule" aria-hidden="true"></span>
      <p class="lp-lead">{d.lead}</p>
      <div class="cta-row">
        {waitlistOn ? (
          <a class="lp-btn primary" href={WAITLIST_URL} target="_blank" rel="noopener">{d.ctaPrimary}<Fragment set:html={arrow} /></a>
        ) : (
          <span class="lp-btn primary is-soon" aria-disabled="true">{soonLabel}</span>
        )}
        <a class="lp-btn ghost" href="#cap">{d.ctaSecondary}</a>
      </div>
      <ul class="chips">
        {d.chips.map((c: string) => (<li>{c}</li>))}
      </ul>
      <p class="waitlist-note">{d.waitlistNote}</p>
    </div>

    <aside class="console" aria-label={d.console.title}>
      <div class="con-head">
        <span class="con-title">{d.console.title}</span>
        <span class="con-tag">{d.console.tag}</span>
      </div>
      <ul class="con-rows">
        {d.console.rows.map((r: { text: string; time: string; state?: string }) => (
          <li class={r.state === 'running' ? 'run' : 'done'}>
            <span class="con-ico"><Fragment set:html={r.state === 'running' ? iconRun : iconCheck} /></span>
            <span class="con-text">{r.text}</span>
            <span class="con-time">{r.time}</span>
          </li>
        ))}
      </ul>
      <p class="con-foot">{d.console.foot}</p>
    </aside>
  </section>

  <section id="cap" class="block features">
    <div class="sec-label">{d.capTitle}</div>
    <h2 class="sec-h" set:html={d.capHeading} />
    <p class="sec-lead">{d.capLead}</p>
    <div class="cap-grid">
      {d.caps.map((c: { title: string; body: string; personal: string; corporate: string }, i: number) => (
        <div class="capcard" style={`--i:${i}`}>
          <div class="cap-top">
            <span class="cap-ico"><Fragment set:html={capIcons[i % capIcons.length]} /></span>
            <span class="cap-num">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div class="cap-title">{c.title}</div>
          <p class="cap-body">{c.body}</p>
          <div class="cap-tags">
            <span class="tag p">{c.personal}</span>
            <span class="tag c">{c.corporate}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="how" class="block">
    <div class="sec-label">{d.howTitle}</div>
    <ol class="steps">
      {d.how.map((step: string) => (<li>{step}</li>))}
    </ol>
  </section>

  <section id="pricing" class="block">
    <div class="sec-label">{d.pricingTitle}</div>
    <div class="price-card">
      <div class="plan">{d.pricing.plan}</div>
      <div class="price">{d.pricing.price}</div>
      <p class="price-note">{d.pricing.note}</p>
    </div>
  </section>

  <section class="block telemetry">
    <div class="sec-label">{d.proofLabel}</div>
    <h2 class="sec-h">{d.proofTitle}</h2>
    <div class="proof-card">
      <p class="proof-caveat">{d.proof.heading}</p>
      <p class="proof-body">{d.proof.body}</p>
      <ul class="proof-points">
        {d.proof.points.map((p: string) => (<li>{p}</li>))}
      </ul>
    </div>
  </section>

  <section id="faq" class="block">
    <div class="sec-label">{d.faqTitle}</div>
    <dl class="faq">
      {d.faq.map((f: { q: string; a: string }) => (
        <>
          <dt>{f.q}</dt>
          <dd>{f.a}</dd>
        </>
      ))}
    </dl>
  </section>

  <section class="closing">
    <h2 class="closing-h">{d.closingTitle}</h2>
    <p class="closing-body">{d.closingBody}</p>
    {waitlistOn ? (
      <a class="lp-btn primary lg" href={WAITLIST_URL} target="_blank" rel="noopener">{d.ctaPrimary}<Fragment set:html={arrow} /></a>
    ) : (
      <span class="lp-btn primary lg is-soon" aria-disabled="true">{soonLabel}</span>
    )}
  </section>
</div>

<style>
  /* シアン→パープルの回転グラデ境界線を意匠の署名にするための角度カスタムプロパティ */
  @property --a { syntax: "<angle>"; inherits: false; initial-value: 0deg; }

  .os-landing{
    --lp-ink:#14171f; --lp-ink2:#39414f; --lp-sub:#6a707c; --lp-faint:#9aa0ac;
    --lp-line:#e6e8ee; --lp-line2:#d3d7e0; --lp-card:#ffffff; --lp-soft:#f5f7fb;
    --lp-accent:#0095f6; --lp-accent-ink:#0077c8;
    --lp-grad-a:#22d3ee; --lp-grad-b:#8b5cf6;
    --lp-grad:linear-gradient(120deg,var(--lp-grad-a),var(--lp-grad-b));
    --lp-round:"SF Pro Rounded","Hiragino Maru Gothic ProN","Segoe UI Rounded","Meiryo","Noto Sans JP",system-ui,-apple-system,sans-serif;
    color:var(--lp-ink);
  }
  :global(body.os){
    background:
      radial-gradient(56% 40% at 2% -6%, rgba(0,149,246,.20), transparent 56%),
      radial-gradient(50% 36% at 100% 0%, rgba(139,92,246,.15), transparent 58%),
      radial-gradient(60% 34% at 98% 104%, rgba(34,211,238,.12), transparent 60%),
      linear-gradient(180deg,#e8eefe 0%, #eef2fd 52%, #eff3fd 100%);
    background-repeat:no-repeat; background-attachment:fixed;
  }
  :global(body.os)::before{
    content:""; position:fixed; inset:0; z-index:0; pointer-events:none;
    background-image:
      linear-gradient(rgba(30,52,130,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30,52,130,.05) 1px, transparent 1px);
    background-size:42px 42px;
    -webkit-mask-image:radial-gradient(120% 90% at 50% 0%, #000 55%, transparent 100%);
            mask-image:radial-gradient(120% 90% at 50% 0%, #000 55%, transparent 100%);
  }
  :global(body.os .wrap){ max-width:1080px; position:relative; z-index:1; }

  /* ── 回転グラデ境界線ユーティリティ（意匠の署名・前面化）── */
  .grad-ring{position:relative}
  .grad-ring::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1.6px;z-index:3;pointer-events:none;
    background:conic-gradient(from var(--a), var(--lp-grad-a), var(--lp-grad-b), var(--lp-accent), var(--lp-grad-a));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;
            mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);mask-composite:exclude;
    animation:borderspin 7s linear infinite}

  @keyframes borderspin{to{--a:360deg}}
  @keyframes rise{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
  @keyframes heroIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
  @keyframes shimmer{to{background-position:220% 0}}

  /* ── nav ─────────────────────────────────────────── */
  .nav{position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:20px;
    padding:14px 20px;margin:0 -20px;
    background:rgba(240,244,253,.72);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(30,52,130,.06)}
  .brand{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:var(--lp-ink)}
  .brand-glyph{width:22px;height:22px;border-radius:7px;flex:none;
    background:radial-gradient(circle at 32% 30%, #fff 0 2px, transparent 3px),linear-gradient(135deg,var(--lp-accent),#4f7cff);
    box-shadow:0 4px 12px -4px rgba(0,149,246,.6);transition:transform .3s cubic-bezier(.2,.7,.2,1)}
  .brand:hover .brand-glyph{transform:rotate(12deg) scale(1.06)}
  .brand-name{font-family:var(--lp-round);font-weight:800;font-size:17px;letter-spacing:-.01em}
  .brand-status{font-family:var(--lp-round);font-weight:800;font-size:10.5px;letter-spacing:.05em;color:var(--lp-sub);
    background:#fff;border:1px solid var(--lp-line2);padding:.18rem .5rem;border-radius:999px;margin-left:2px}
  .nav-links{display:flex;gap:22px;margin-left:8px}
  .nav-links a{position:relative;font-family:var(--lp-round);font-weight:700;font-size:13.5px;color:var(--lp-ink2);text-decoration:none;transition:color .15s ease}
  .nav-links a::after{content:"";position:absolute;left:0;right:100%;bottom:-5px;height:2px;border-radius:2px;background:var(--lp-grad);transition:right .25s ease}
  .nav-links a:hover{color:var(--lp-accent-ink)}
  .nav-links a:hover::after{right:0}
  .nav-right{margin-left:auto;display:flex;align-items:center;gap:12px}

  /* ── buttons ─────────────────────────────────────── */
  .lp-btn{position:relative;display:inline-flex;align-items:center;gap:.4rem;font-family:var(--lp-round);font-weight:800;
    font-size:14.5px;text-decoration:none;border-radius:999px;line-height:1;padding:.72rem 1.2rem;
    border:1px solid transparent;white-space:nowrap;
    transition:transform .16s ease,box-shadow .16s ease,background .16s ease,border-color .16s ease,color .16s ease}
  .lp-btn.sm{font-size:13px;padding:.55rem .95rem}
  .lp-btn.lg{font-size:15.5px;padding:.85rem 1.5rem}
  .lp-btn :global(svg){width:15px;height:15px;transition:transform .16s ease}
  .lp-btn.primary{background:var(--lp-accent);color:#fff;box-shadow:0 4px 14px -5px rgba(0,149,246,.55)}
  .lp-btn.primary:hover{transform:translateY(-2px);box-shadow:0 10px 24px -6px rgba(0,149,246,.55),0 6px 20px -8px rgba(139,92,246,.5)}
  .lp-btn.primary:hover :global(svg){transform:translateX(3px)}
  .lp-btn.primary.is-soon{background:#bcd7ee;color:#fff;box-shadow:none;cursor:default}
  .lp-btn.primary.is-soon:hover{transform:none;box-shadow:none}
  .lp-btn.ghost{background:#fff;color:var(--lp-ink)}
  /* ghost: hover でシアン→パープルの境界線が浮く */
  .lp-btn.ghost{border:1px solid var(--lp-line2)}
  .lp-btn.ghost::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1.4px;pointer-events:none;opacity:0;
    background:var(--lp-grad);-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;
            mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);mask-composite:exclude;transition:opacity .25s ease}
  .lp-btn.ghost:hover{transform:translateY(-2px);border-color:transparent;color:var(--lp-accent-ink)}
  .lp-btn.ghost:hover::before{opacity:1}

  /* ── hero ────────────────────────────────────────── */
  .hero{display:grid;grid-template-columns:1.08fr .92fr;gap:44px;align-items:center;padding:52px 0 40px}
  .eyebrow{position:relative;display:inline-flex;align-items:center;gap:.5rem;font-family:var(--lp-round);font-weight:800;
    font-size:12.5px;letter-spacing:.05em;color:var(--lp-accent-ink);
    background:rgba(0,149,246,.10);border:1px solid transparent;padding:.42rem .9rem;border-radius:999px;
    box-shadow:0 4px 14px -8px rgba(0,149,246,.5)}
  .eyebrow::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1.2px;pointer-events:none;
    background:conic-gradient(from var(--a),var(--lp-grad-a),var(--lp-grad-b),var(--lp-accent),var(--lp-grad-a));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;
            mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);mask-composite:exclude;animation:borderspin 9s linear infinite}
  .eyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--lp-grad);animation:pulse 2.4s ease-in-out infinite}
  .lp-h1{font-family:var(--lp-round);font-weight:800;letter-spacing:-.025em;line-height:1.16;
    font-size:clamp(33px,5.2vw,50px);margin:18px 0 0;text-wrap:balance;color:var(--lp-ink)}
  .h1-rule{display:block;width:132px;height:5px;border-radius:5px;margin:16px 0 0;
    background:linear-gradient(90deg,var(--lp-grad-a),var(--lp-grad-b),var(--lp-grad-a));background-size:220% 100%;
    animation:shimmer 4.5s linear infinite}
  .lp-lead{margin:18px 0 0;color:var(--lp-ink2);font-size:16px;line-height:1.85;max-width:46ch}
  .cta-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .chips{list-style:none;display:flex;flex-wrap:wrap;gap:8px 18px;margin:20px 0 0;padding:0}
  .chips li{position:relative;padding-left:18px;font-family:var(--lp-round);font-weight:700;font-size:12.5px;color:var(--lp-sub)}
  .chips li::before{content:"";position:absolute;left:2px;top:.42em;width:7px;height:7px;border-radius:50%;background:var(--lp-grad)}
  .waitlist-note{margin:16px 0 0;font-size:12.5px;line-height:1.65;color:var(--lp-sub);max-width:48ch}

  /* console = 動作イメージ（回転グラデ境界線で"稼働中"を表現） */
  .console{position:relative;background:var(--lp-card);border-radius:20px;padding:20px 20px 16px;
    box-shadow:0 26px 60px -30px rgba(40,30,120,.5),0 3px 10px -4px rgba(20,30,80,.12)}
  .console::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1.7px;z-index:3;pointer-events:none;
    background:conic-gradient(from var(--a), var(--lp-grad-a), var(--lp-grad-b), var(--lp-accent), var(--lp-grad-a));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;
            mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);mask-composite:exclude;
    animation:borderspin 7s linear infinite}
  .con-head,.con-rows,.con-foot{position:relative;z-index:2}
  .con-head{display:flex;align-items:center;justify-content:space-between;padding-bottom:14px;border-bottom:1px solid var(--lp-line)}
  .con-title{font-family:var(--lp-round);font-weight:800;font-size:14px;color:var(--lp-ink)}
  .con-tag{font-family:var(--lp-round);font-weight:800;font-size:10.5px;letter-spacing:.04em;color:#fff;
    background:var(--lp-grad);padding:.24rem .6rem;border-radius:999px}
  .con-rows{list-style:none;margin:6px 0 0;padding:0}
  .con-rows li{display:flex;align-items:center;gap:12px;padding:11px 2px;border-bottom:1px solid #f0f2f7;
    animation:rise .5s cubic-bezier(.2,.7,.2,1) both}
  .con-rows li:nth-child(1){animation-delay:.35s}.con-rows li:nth-child(2){animation-delay:.47s}
  .con-rows li:nth-child(3){animation-delay:.59s}.con-rows li:nth-child(4){animation-delay:.71s}
  .con-rows li:last-child{border-bottom:none}
  .con-ico{flex:none;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center}
  .con-ico :global(svg){width:13px;height:13px}
  .con-rows li.done .con-ico{background:rgba(0,149,246,.12);color:var(--lp-accent-ink)}
  .con-rows li.run .con-ico{background:linear-gradient(135deg,rgba(34,211,238,.2),rgba(139,92,246,.2));color:#6d4bd0}
  .con-rows li.run .con-ico :global(svg){animation:borderspin 1.4s linear infinite}
  .con-text{flex:1;font-size:13.5px;color:var(--lp-ink2);line-height:1.35}
  .con-time{font-family:var(--lp-round);font-weight:700;font-size:12px;color:var(--lp-faint);white-space:nowrap}
  .con-rows li.run .con-time{color:#6d4bd0;animation:pulse 1.8s ease-in-out infinite}
  .con-foot{margin:14px 0 0;font-size:11px;line-height:1.55;color:var(--lp-faint)}

  /* ── section scaffolding ─────────────────────────── */
  .block{margin-top:64px}
  .sec-label{font-family:var(--lp-round);font-size:12px;letter-spacing:.14em;text-transform:uppercase;
    font-weight:800;margin-bottom:12px;
    background:var(--lp-grad);-webkit-background-clip:text;background-clip:text;color:transparent}
  .sec-h{font-family:var(--lp-round);font-weight:800;letter-spacing:-.02em;line-height:1.2;
    font-size:clamp(24px,3.6vw,34px);color:var(--lp-ink)}
  .sec-lead{margin:12px 0 0;color:var(--lp-ink2);font-size:15px;line-height:1.8;max-width:52ch}

  /* features grid — 常時うっすらグラデ境界線＋回転、hover で前面化＆浮上 */
  .features .cap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:28px}
  .capcard{position:relative;background:var(--lp-card);border-radius:18px;padding:22px 22px 20px;
    box-shadow:0 3px 10px -4px rgba(20,30,80,.12);
    transition:transform .24s cubic-bezier(.2,.7,.2,1),box-shadow .24s ease}
  .capcard::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1.5px;z-index:3;pointer-events:none;opacity:.5;
    background:conic-gradient(from calc(var(--a) + var(--i,0)*40deg), var(--lp-grad-a), var(--lp-grad-b), var(--lp-grad-a));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;
            mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);mask-composite:exclude;
    animation:borderspin 9s linear infinite;transition:opacity .28s ease}
  .capcard:hover{transform:translateY(-4px);box-shadow:0 20px 40px -20px rgba(40,30,120,.34)}
  .capcard:hover::before{opacity:1}
  .cap-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
  .cap-ico{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;
    background:linear-gradient(160deg,rgba(34,211,238,.18),rgba(139,92,246,.18));color:#5a5ad0;
    transition:transform .3s cubic-bezier(.2,.7,.2,1)}
  .capcard:hover .cap-ico{transform:scale(1.08) rotate(-4deg)}
  .cap-ico :global(svg){width:22px;height:22px}
  .cap-num{font-family:var(--lp-round);font-weight:800;font-size:13px;
    background:var(--lp-grad);-webkit-background-clip:text;background-clip:text;color:transparent;opacity:.65}
