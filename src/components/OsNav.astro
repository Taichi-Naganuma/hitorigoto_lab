---
// Mioca サブサイト共通ナビ（LP＋機能/しくみ/料金の専用ページで共有）。
// 併せて「スクロールで再入するたびに再生される」リビール制御スクリプトを1回だけ載せる。
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Locale } from '../i18n/ui';
import { WAITLIST_URLS, OS_BRAND, osStatus, osCta, osNav } from '../lib/os';

interface Props { locale: Locale; active?: string }
const { locale, active = '' } = Astro.props;
const t = useTranslations(locale);
const osHome = getRelativeLocaleUrl(locale, '/os/');
const items = osNav(locale).map((n) => ({
  ...n,
  href: n.anchor ? `${osHome}#${n.slug}` : getRelativeLocaleUrl(locale, `/os/${n.slug}/`),
}));
const waitlist = WAITLIST_URLS[locale] ?? '';
const cta = osCta(locale);
const soon = locale === 'ja' ? '先行登録（準備中）' : 'Waitlist — opening soon';

// 言語切替は「同じページの他言語版」へ（無ければ他言語の /os/ へフォールバック）。
const other: Locale = locale === 'ja' ? 'en' : 'ja';
const otherUrl = Astro.url.pathname.replace(new RegExp(`^/${locale}/`), `/${other}/`) || getRelativeLocaleUrl(other, '/os/');
---

<header class="os-nav">
  <a class="brand" href={osHome} aria-label={OS_BRAND}>
    <span class="brand-glyph"></span><span class="brand-name">{OS_BRAND}</span>
    <span class="brand-status">{osStatus(locale)}</span>
  </a>
  <nav class="nav-links" aria-label="section">
    {items.map((n) => <a href={n.href} class={active === n.slug ? 'on' : ''}>{n.label}</a>)}
  </nav>
  <div class="nav-right">
    <a class="lang" href={otherUrl} hreflang={other} lang={other}>{t('lang.switch')}</a>
    {waitlist ? (
      <a class="nav-cta" href={waitlist} target="_blank" rel="noopener">{cta}</a>
    ) : (
      <span class="nav-cta soon" aria-disabled="true">{soon}</span>
    )}
  </div>
</header>

<style>
  .os-nav{position:sticky;top:0;z-index:30;display:flex;align-items:center;gap:20px;padding:14px 20px;margin:0 -20px;
    font-family:"SF Pro Rounded","Hiragino Maru Gothic ProN","Segoe UI Rounded","Meiryo","Noto Sans JP",system-ui,sans-serif;
    background:rgba(240,244,253,.72);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(30,52,130,.06)}
  .brand{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:#14171f}
  .brand-glyph{width:22px;height:22px;border-radius:7px;flex:none;
    background:radial-gradient(circle at 32% 30%, #fff 0 2px, transparent 3px),linear-gradient(135deg,#0095f6,#4f7cff);
    box-shadow:0 4px 12px -4px rgba(0,149,246,.6);transition:transform .3s cubic-bezier(.2,.7,.2,1)}
  .brand:hover .brand-glyph{transform:rotate(12deg) scale(1.06)}
  .brand-name{font-weight:800;font-size:17px;letter-spacing:-.01em}
  .brand-status{font-weight:800;font-size:10.5px;letter-spacing:.05em;color:#6a707c;background:#fff;
    border:1px solid #d3d7e0;padding:.18rem .5rem;border-radius:999px;margin-left:2px}
  .nav-links{display:flex;gap:22px;margin-left:8px}
  .nav-links a{position:relative;font-weight:700;font-size:13.5px;color:#39414f;text-decoration:none;transition:color .15s ease}
  .nav-links a::after{content:"";position:absolute;left:0;right:100%;bottom:-5px;height:2px;border-radius:2px;
    background:linear-gradient(120deg,#22d3ee,#8b5cf6);transition:right .25s ease}
  .nav-links a:hover,.nav-links a.on{color:#0077c8}
  .nav-links a:hover::after,.nav-links a.on::after{right:0}
  .nav-right{margin-left:auto;display:flex;align-items:center;gap:12px}
  .lang{color:#6a707c;text-decoration:none;font-size:12.5px;font-weight:700;padding:6px 14px;border:1px solid #d3d7e0;
    border-radius:999px;transition:color .15s ease,border-color .15s ease}
  .lang:hover{color:#14171f;border-color:#14171f}
  .nav-cta{font-weight:800;font-size:13px;text-decoration:none;color:#fff;background:#0095f6;padding:.55rem .95rem;
    border-radius:999px;white-space:nowrap;box-shadow:0 4px 14px -5px rgba(0,149,246,.55);
    transition:transform .16s ease,box-shadow .16s ease}
  .nav-cta:hover{transform:translateY(-2px);box-shadow:0 10px 24px -6px rgba(0,149,246,.55),0 6px 20px -8px rgba(139,92,246,.5)}
  .nav-cta.soon{background:#bcd7ee;cursor:default}
  .nav-cta.soon:hover{transform:none;box-shadow:none}
  @media (max-width:820px){ .nav-links{display:none} }
</style>

<script is:inline>
  // リビール制御: 対象がビューポートに入るたびに .in を付け直す＝2回目以降も毎回アニメーションする。
  // reveal-on は即時付与（親 .os-* は既にパース済＝ちらつき防止）、対象探索は DOM 構築後に行う。
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('IntersectionObserver' in window)) return;
    var early = document.querySelector('.os-landing, .os-page');
    if (early) early.classList.add('reveal-on');
    function init() {
      var root = document.querySelector('.os-landing, .os-page');
      if (!root) return;
      var sel = ['.hero-copy > *', '.console', '.sec-label', '.sec-h', '.sec-lead', '.capcard',
        '.steps li', '.price-card', '.proof-card', '.faq dt', '.faq dd', '.closing',
        '.o-hero > *', '.o-card', '.o-steps li', '.o-points li', '.o-note', '.o-closing'].join(',');
      var targets = root.querySelectorAll(sel);
      targets.forEach(function (el) {
        var sibs = el.parentNode ? el.parentNode.children : [el];
        el.style.setProperty('--ri', Array.prototype.indexOf.call(sibs, el) % 8);
      });
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { e.target.classList.toggle('in', e.isIntersecting); });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      targets.forEach(function (el) { io.observe(el); });
      // 安全網: observer が一度も発火しない環境では 1.6s 後に全て表示（隠れっぱなし防止）。
      setTimeout(function () { if (!root.querySelector('.in')) targets.forEach(function (el) { el.classList.add('in'); }); }, 1600);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
