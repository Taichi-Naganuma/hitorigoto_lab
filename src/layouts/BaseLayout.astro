---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import StripeAttribution from '../components/StripeAttribution.astro';

interface Props {
  locale: 'ja' | 'en';
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  variant?: 'home' | 'product' | 'legal';
  noindex?: boolean;
  showFooter?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const {
  locale,
  title,
  description,
  ogTitle,
  ogDescription,
  variant = 'product',
  noindex = false,
  showFooter = true,
  jsonLd = [],
} = Astro.props;

const og = { title: ogTitle ?? title, description: ogDescription ?? description };

// GEO: エンティティ確立。全ページに Organization(発信主体 hitorigotolab＋製品ブランド Mioca)を出す。
// AI検索がエンティティ解決・被引用しやすくする土台。ページ固有(Article 等)は jsonLd で追加注入。
const site = 'https://hitorigotolab.mananect.com';
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'hitorigotolab',
  url: site,
  brand: { '@type': 'Brand', name: 'Mioca' },
};
const allLd = [orgLd, ...jsonLd];
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={og.title} />
    {og.description && <meta property="og:description" content={og.description} />}
    {allLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class={variant}>
    <div class="wrap">
      <slot />
      {showFooter && <Footer locale={locale} variant={variant} />}
    </div>
    <StripeAttribution />
  </body>
</html>
