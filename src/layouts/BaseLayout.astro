---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/site-fx.css';
import Footer from '../components/Footer.astro';
import StripeAttribution from '../components/StripeAttribution.astro';

interface Props {
  locale: 'ja' | 'en';
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  variant?: 'home' | 'product' | 'legal' | 'os';
  bodyClass?: string; // 追加の body クラス（例 "fx-bg"＝オーロラ＋OS連想グリッド）
  noindex?: boolean;
  showFooter?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const {
  locale,
  title,
  description,
  ogTitle,
  ogDescription,
  variant = 'product',
  bodyClass,
  noindex = false,
  showFooter = true,
  jsonLd = [],
} = Astro.props;

const og = { title: ogTitle ?? title, description: ogDescription ?? description };

// GEO: エンティティ確立。全ページに Organization(発信主体 hitorigotolab＋製品ブランド Mioca)を出す。
// AI検索がエンティティ解決・被引用しやすくする土台。ページ固有(Article 等)は jsonLd で追加注入。
const site = 'https://hitorigotolab.mananect.com';
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'hitorigotolab',
  url: site,
  brand: { '@type': 'Brand', name: 'Mioca' },
};
const allLd = [orgLd, ...jsonLd];

// タブ/ブックマークのアイコン（顔ごと）: /os/(Mioca LP)=周回リング、それ以外(購買部/記事)=研究所の吹き出し。
const favicon = variant === 'os' ? '/mioca.svg' : '/favicon.svg';
const icon32 = variant === 'os' ? '/mioca-32.png' : '/favicon-32.png';
const appleIcon = variant === 'os' ? '/apple-touch-icon-mioca.png' : '/apple-touch-icon.png';
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="icon" type="image/png" sizes="32x32" href={icon32} />
    <link rel="apple-touch-icon" href={appleIcon} />
    <meta name="theme-color" content="#0095f6" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={og.title} />
    {og.description && <meta property="og:description" content={og.description} />}
    {allLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
    <script is:inline>
      // 下から浮上リビール制御（.fx-rise 要素があるページのみ実効）。head で html.fx-on を即時付与＝ちらつき防止。
      // 入ったら .in・**完全に画面外へ出たときだけ**外す（アニメ中の位置変化で再発火する無限ループを防ぐ）。
      (function () {
        try {
          if (matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) return;
          document.documentElement.classList.add('fx-on');
          function init() {
            var t = document.querySelectorAll('.fx-rise');
            if (!t.length) return;
            t.forEach(function (el) { var s = el.parentNode ? el.parentNode.children : [el]; el.style.setProperty('--ri', Array.prototype.indexOf.call(s, el) % 8); });
            var vh = function () { return window.innerHeight || document.documentElement.clientHeight; };
            var io = new IntersectionObserver(function (es) {
              es.forEach(function (e) {
                if (e.isIntersecting) el_add(e.target);
                else { var r = e.boundingClientRect; if (r.bottom <= 4 || r.top >= vh() - 4) e.target.classList.remove('in'); }
              });
            }, { threshold: 0.15 });
            function el_add(x) { x.classList.add('in'); }
            t.forEach(function (el) { io.observe(el); });
            setTimeout(function () { if (!document.querySelector('.fx-rise.in')) t.forEach(function (el) { el.classList.add('in'); }); }, 1600);
          }
          if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
        } catch (e) { document.documentElement.classList.remove('fx-on'); }
      })();
    </script>
  </head>
  <body class:list={[variant, bodyClass]}>
    <div class="wrap">
      <slot />
      {showFooter && <Footer locale={locale} variant={variant} />}
    </div>
    <StripeAttribution />
  </body>
</html>
