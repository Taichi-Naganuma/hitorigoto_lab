---
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeLanding from '../../components/HomeLanding.astro';
import { getHome, getProductsByLocale, productSlug } from '../../lib/products';

const locale = 'en';
const home = await getHome(locale);
const products = await getProductsByLocale(locale);
const h = home.data;
const items = products.map((p) => ({
  title: p.data.card.title,
  price: p.data.card.price,
  blurb: p.data.card.blurb,
  cta: p.data.card.cta,
  href: getRelativeLocaleUrl(locale, `/${productSlug(p.id)}/`),
}));
---

<BaseLayout
  locale={locale}
  variant="home"
  title={h.title}
  description={h.description}
  ogTitle={h.ogTitle}
  ogDescription={h.ogDescription}
>
  <HomeLanding locale={locale} h={h} products={items} />
</BaseLayout>
