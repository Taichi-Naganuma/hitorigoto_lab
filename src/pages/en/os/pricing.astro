---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OsSubPage from '../../../components/OsSubPage.astro';
import { getOsPage } from '../../../lib/os';

const locale = 'en';
const d = await getOsPage(locale, 'pricing');
---

<BaseLayout locale={locale} variant="os" title={d.title} description={d.description} ogTitle={d.ogTitle} ogDescription={d.ogDescription}>
  <OsSubPage locale={locale} d={d} />
</BaseLayout>
